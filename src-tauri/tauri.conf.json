{
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist",
    "withGlobalTauri": false
  },
  "package": {
    "productName": "Cephalon Kronos",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "notification": {
        "all": true
      },
      "protocol": {
        "asset": true,
        "assetScope": [
          "**"
        ]
      },
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.glowseeker.cephalonkronos",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico",
        "icons/icon.png"
      ],
      "resources": [
        "data/bin/*",
        "data/export/*",
        "../public/audio/*"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "Cephalon Kronos",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 500
      },
      {
        "label": "overlay-tr",
        "title": "Kronos Overlay TR",
        "width": 320,
        "height": 90,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "url": "/#overlay",
        "acceptFirstMouse": true,
        "focus": false
      },
      {
        "label": "overlay-tl",
        "title": "Kronos Overlay TL",
        "width": 320,
        "height": 90,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "url": "/#overlay",
        "acceptFirstMouse": true,
        "focus": false
      },
      {
        "label": "overlay-tc",
        "title": "Kronos Overlay TC",
        "width": 580,
        "height": 220,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "resizable": false,
        "visible": false,
        "skipTaskbar": true,
        "url": "/#overlay",
        "acceptFirstMouse": true,
        "focus": false
      },
      {
        "label": "calibration",
        "title": "Kronos Overlay",
        "width": 600,
        "height": 400,
        "decorations": true,
        "resizable": true,
        "visible": false,
        "url": "/#calibration"
      }
    ]
  }
}